{$DOMAIN:localhost} {
    # API -> backend
    handle /api/* {
        reverse_proxy backend:8000
    }

    # Health check
    handle /health {
        reverse_proxy backend:8000
    }

    # Docs
    handle /docs {
        reverse_proxy backend:8000
    }
    handle /openapi.json {
        reverse_proxy backend:8000
    }

    # Frontend
    handle {
        reverse_proxy frontend:3000
    }

    # Compression
    encode gzip

    # Security headers
    header {
        X-Frame-Options DENY
        X-Content-Type-Options nosniff
        Referrer-Policy no-referrer-when-downgrade
        X-XSS-Protection "1; mode=block"
    }
}
